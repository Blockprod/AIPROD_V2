          "emotional_beat_index": 0.69
        },
        {
          "scene_id": "SCN_009",
          "characters": [
            "NARA",
            "MIRA"
          ],
          "character_ids": [
            "nara",
            "mira"
          ],
          "location": "INT. EXTERNAL OBSERVATION CHAMBER - CONTINUOUS",
          "location_id": "int_external_observation_chamber_continuous",
          "time_of_day": "interior",
          "visual_actions": [
            "Ancient shutters peel open and reveal organized lights far beyond the wall.",
            "Nara realizes District Zero lied about the outside world.",
            "A series of details register in rapid succession: industrial pumps hidden in the wall structure dumping poison into the lower sectors.",
            "A silent alarm floods the chamber red."
          ],
          "dialogues": [
            "They lied.",
            "We need to go. Now."
          ],
          "emotion": "neutral",
          "action_units": [],
          "shot_ids": [
            "SCN_009_SHOT_001",
            "SCN_009_SHOT_002",
            "SCN_009_SHOT_003",
