        {
          "scene_id": "SCN_002",
          "characters": [
            "NARA"
          ],
          "character_ids": [
            "nara"
          ],
          "location": "INT. LOWER TRANSIT STACK - SERVICE CORRIDOR - NIGHT",
          "location_id": "int_lower_transit_stack_service_corridor_night",
          "time_of_day": "night",
          "visual_actions": [
            "Nara Voss runs through a leaking maintenance corridor as her wrist display flashes a pressure alert.",
            "On the map, a sealed route appears for a second and vanishes.",
            "She captures the image and keeps moving.",
            "She enters the unmapped access corridor alone."
          ],
          "dialogues": [
            "That route was deleted."
          ],
          "emotion": "neutral",
          "action_units": [],
          "shot_ids": [
            "SCN_002_SHOT_001",
            "SCN_002_SHOT_002",
            "SCN_002_SHOT_003",
