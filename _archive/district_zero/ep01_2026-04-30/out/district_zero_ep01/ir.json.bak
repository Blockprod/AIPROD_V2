            "SCN_009_SHOT_006"
          ],
          "beat_type": "action",
          "scene_tone": null,
          "emotional_beat_index": 0.76
        },
        {
          "scene_id": "SCN_010",
          "characters": [
            "HANDHELD FAST"
          ],
          "character_ids": [
            "handheld_fast"
          ],
          "location": "INT. SERVICE SPINE - CONTINUOUS",
          "location_id": "int_service_spine_continuous",
          "time_of_day": "interior",
          "visual_actions": [
            "At the far end, armed units pour into the shaft entrance.",
            "VALE (V.O. OVER COMMS)",
            "Nara Voss. Stop running. The truth is not what you think it is.",
            "Mira disappears into a side duct and Nara escapes behind a closing blast door.",
            "Silence."
          ],
          "dialogues": [
            "Security shutters slam down the corridor as Nara and Mira sprint through narrowing gaps."
          ],
          "emotion": "neutral",
          "action_units": [],
          "shot_ids": [
            "SCN_010_SHOT_001",
            "SCN_010_SHOT_002",
            "SCN_010_SHOT_003",
            "SCN_010_SHOT_004",
